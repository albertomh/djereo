# {{project_name}} - local development tooling

set positional-arguments

call_recipe := just_executable() + " --justfile=" + justfile()

default_addrport := '127.0.0.1:8000'

default:
  @just --list

collectstatic:
  #!/usr/bin/env bash
  # It would be simpler to use just's `dotenv-load`. However, this is not a viable
  # approach since this would also load `.env` for the `test` recipe. Meaning the
  # environment `test` runs in would be polluted instead of using values from `.env.test`.
  set -euo pipefail
  # Skip collectstatic if DEBUG is True (development mode).
  if uv run python -c "from environs import Env; env = Env(); env.read_env(recurse=False); exit(0 if env.bool('DEBUG', default=False) else 1)"; then
    exit 0
  fi
  rm -rf static/
  uv run manage.py collectstatic --noinput

_dev_setup:
  @test -d .venv/ || uv venv
  @test -x .venv/bin/django-admin || uv sync --dev
  @uv pip install -e .
{% raw %}  {{call_recipe}} collectstatic{% endraw %}


set_up_db $APP_USER_PASSWORD="password":
  @APP_USER_PASSWORD={{APP_USER_PASSWORD}} uv run _db/manage_db.py set_up

tear_down_db $APP_USER_PASSWORD="password":
  @APP_USER_PASSWORD={{APP_USER_PASSWORD}} uv run _db/manage_db.py tear_down

manage +args='help': _dev_setup
  @uv run manage.py "$@"

runserver addrport=default_addrport $PYTHONDEVMODE="1": _dev_setup
  # Disable PYTHONDEVMODE by passing an empty string ie. `just runserver 127.0.0.1:8000 ""`
  # Only start Mailpit if the SMTP port (1025) is not already listening
  @uv run python -c "import socket; s=socket.socket(); s.settimeout(0.1); s.connect(('127.0.0.1', 1025))" 2>/dev/null || (MP_DATABASE=mailpit.db mailpit &)
{% raw %}  @uv run manage.py runserver {{addrport}}{% endraw +%}

shell: _dev_setup
  @uv run manage.py shell

_test_setup:
  @test -d .venv/ || uv venv
  @test -x .venv/bin/coverage || uv sync --group test
  @uv pip install -e .

profile_tests: _test_setup
  @sudo py-spy record --subprocesses --format speedscope -o profile.speedscope.json -- \
    uv run python manage.py test

e2e $USE_ENV_TEST="1": _test_setup
  #!/usr/bin/env bash
  set -euo pipefail

  cleanup() {
    [ -n "${SERVER_PID:-}" ] && kill "$SERVER_PID" 2>/dev/null || true
    if [ "${STARTED_MAILPIT:-}" = true ]; then
      [ -n "${MAILPIT_PID:-}" ] && kill "$MAILPIT_PID" 2>/dev/null || true
    fi
  }
  trap cleanup EXIT

  # Only start Mailpit if the SMTP port (1025) is not already listening
  STARTED_MAILPIT=false
  if ! uv run python -c "import socket; s=socket.socket(); s.settimeout(0.1); s.connect(('127.0.0.1', 1025))" 2>/dev/null; then
    mailpit &
    MAILPIT_PID=$!
    STARTED_MAILPIT=true
  fi
  uv run manage.py flush --no-input
  uv run manage.py migrate
  uv run manage.py seed_database
  uv run manage.py runserver "" &
  SERVER_PID=$!
  uv run pytest tests_e2e/
