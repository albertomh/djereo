# Usage:
#
# ```
# # run docker commands from the project root, ie. the parent directory of `_deploy/`
#
# docker network create {{project_name}}_net
# docker image pull --platform linux/amd64 <registry>/<image>:<tag>
#
# docker run --detach \
#     --init \
#     --name <container_name> \
#     --env-file "<path_to_dotenv>" \
#     --env "PORT=8000" \
#     --network <network_name> \
#     --publish "8000:8000" \
#     --volume <db_volume>:/app/data \
#     --volume <static_volume>:/app/static \
#     --env "DATABASE_URL=sqlite:////app/data/db.sqlite3" \
#     --restart always \
#     <registry>/<image>:<tag>
# ```
#
# Based on <https://github.com/astral-sh/uv-docker-example/blob/main/Dockerfile>

FROM python:{{min_python_version}}-slim-bookworm AS builder
COPY --from=ghcr.io/astral-sh/uv:0.11.9 /uv /uvx /bin/

# - Silence uv complaining about not being able to use hard links.
# - Enable bytecode compilation - trade longer installation for faster start-up times.
# - Prevent uv from accidentally downloading isolated Python builds.
# - Declare `/app` as the target for `uv sync`.
ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

# Synchronise dependencies (creates .venv)
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync \
        --frozen \
        --no-dev \
        --no-install-project

COPY . .
COPY _deploy/.env.deploy .env
COPY _deploy/gunicorn.conf.py gunicorn.conf.py

# Install the webapp (dependencies already installed by `uv sync`)
RUN uv pip install . --no-deps

RUN python manage.py collectstatic --noinput \
    && rm .env

# ----------------------------------------------------------------------------------------
# runtime stage

FROM python:{{min_python_version}}-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

RUN useradd \
  --system \
  --no-create-home \
  --shell /usr/sbin/nologin \
  nonroot

COPY --from=builder --chown=nonroot:nonroot /app /app

RUN mkdir -p /app/data \
    && chown -R nonroot:nonroot /app/data

RUN mkdir -p /app/static \
    && chown -R nonroot:nonroot /app/static

USER nonroot

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:%s/-/alive/' % __import__('os').environ['PORT'])" || exit 1

ENTRYPOINT []

CMD ["gunicorn", "-c", "gunicorn.conf.py", "{{project_name}}.wsgi:application"]
