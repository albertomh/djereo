import getpass
import os

import psycopg
from psycopg import sql


def get_postgres_user() -> str:
    if os.getenv("CI") == "true":
        return "postgres"
    return getpass.getuser()


def set_up():
    user = get_postgres_user()
    password = (
        "password"
        if os.getenv("CI") == "true"
        else os.getenv("APP_USER_PASSWORD", "password")
    )
    dbname = "postgres"
    conn_str = f"host=localhost user={user} dbname={dbname}"
    if os.getenv("CI") == "true":
        conn_str += " password=password"

    project_name = "{{project_name}}"

    with psycopg.connect(conn_str, autocommit=True) as conn:
        with conn.cursor() as cur:
            for name in [project_name, f"test_{project_name}"]:
                print(f"Setting up database and user for: {name}")

                # Terminate connections to all databases owned by the user
                cur.execute(
                    """
                    SELECT pg_terminate_backend(pid)
                    FROM pg_stat_activity
                    WHERE datname IN (
                        SELECT datname FROM pg_database
                        WHERE datdba = (SELECT oid FROM pg_roles WHERE rolname = %s)
                    ) AND pid <> pg_backend_pid();
                    """,
                    (name,),
                )

                # Drop all databases owned by the user
                cur.execute(
                    """
                    SELECT datname FROM pg_database
                    WHERE datdba = (SELECT oid FROM pg_roles WHERE rolname = %s);
                    """,
                    (name,),
                )
                owned_databases = [row[0] for row in cur.fetchall()]
                for db in owned_databases:
                    cur.execute(
                        sql.SQL("DROP DATABASE IF EXISTS {}").format(sql.Identifier(db))
                    )

                cur.execute(
                    sql.SQL("DROP USER IF EXISTS {}").format(sql.Identifier(name))
                )

                cur.execute(
                    sql.SQL("CREATE USER {} WITH PASSWORD {}").format(
                        sql.Identifier(name), sql.Literal(password)
                    )
                )
                cur.execute(
                    sql.SQL("ALTER USER {} CREATEDB").format(sql.Identifier(name))
                )
                cur.execute(
                    sql.SQL("CREATE DATABASE {} OWNER {}").format(
                        sql.Identifier(name), sql.Identifier(name)
                    )
                )


if __name__ == "__main__":
    set_up()
