from django.apps import AppConfig
from django.core import checks


class CoreConfig(AppConfig):
    name = "core"

    def ready(self) -> None:
        from core.checks import (  # noqa: PLC0415
            check_dev_mode,
            check_model_names,
        )

        checks.register(check_dev_mode)
        checks.register(check_model_names)
