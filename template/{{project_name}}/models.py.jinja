import uuid

from django.db import models
from django.utils import timezone


{% set python_ver_parts = min_python_version.split('.') %}
{% set python_ver_minor = python_ver_parts[1] | int -%}

class UuidModel(models.Model):
    id: models.UUIDField = models.UUIDField(
        {% if python_ver_minor < 14 %}
        primary_key=True, default=uuid.uuid4, editable=False
        {% else %}
        primary_key=True, default=uuid.uuid7, editable=False
        {% endif %}
    )

    class Meta:
        abstract = True


class CreatedAtModel(models.Model):
    created_at: models.DateTimeField = models.DateTimeField(auto_now_add=True)

    class Meta:
        abstract = True


class UpdatedAtModel(models.Model):
    updated_at: models.DateTimeField = models.DateTimeField(auto_now=True)

    class Meta:
        abstract = True


class DeletedAtQuerySet(models.QuerySet):
    def deleted(self):
        return self.filter(deleted_at__isnull=False)

    def live(self):
        return self.filter(deleted_at__isnull=True)


class DeletedAtManager(models.Manager):
    def get_queryset(self):
        return DeletedAtQuerySet(self.model, using=self._db).live()

    def deleted(self):
        return DeletedAtQuerySet(self.model, using=self._db).deleted()

    def all_with_deleted(self):
        return DeletedAtQuerySet(self.model, using=self._db)


class DeletedAtModel(models.Model):
    """Abstract model for soft-deletion.

    Usage:
        >>> obj.soft_delete()  # sets deleted_at and hides from default manager
        >>> obj.restore()      # clears deleted_at and makes visible again
        >>> MyModel.objects.all()               # only live records
        >>> MyModel.objects.deleted()           # only deleted records
        >>> MyModel.objects.all_with_deleted()  # both live and deleted records
    """

    deleted_at: models.DateTimeField = models.DateTimeField(
        blank=True, null=True, default=None, editable=False
    )

    objects = DeletedAtManager()

    def soft_delete(self):
        self.deleted_at = timezone.now()
        self.save(update_fields=["deleted_at"])

    def restore(self):
        self.deleted_at = None
        self.save(update_fields=["deleted_at"])

    class Meta:
        abstract = True
