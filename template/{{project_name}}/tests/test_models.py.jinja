{% set python_ver_parts = min_python_version.split('.') %}
{% set python_ver_minor = python_ver_parts[1] | int %}
from datetime import timedelta

from django.test import TestCase
from django.utils.timezone import now

from {{project_name}}.tests.test_app.models import (
    TestModelCreatedAt,
    TestModelDeletedAt,
    TestModelUpdatedAt,
    {% if python_ver_minor >= 14 %}
    TestModelUuid,
    {% endif %}
)


class ModelTestCase(TestCase):
    {% if python_ver_minor >= 14 %}
    def test_uuidmodel_id_is_monotonic(self):
        m1 = TestModelUuid()
        m2 = TestModelUuid()

        # uuid7 embeds timestamp bits - IDs of two models created in sequence are ordered.
        self.assertLess(m1.id, m2.id)

    {% endif %}
    def test_created_at_field_on_creation(self):
        obj = TestModelCreatedAt.objects.create()
        self.assertIsNotNone(obj.created_at)
        self.assertAlmostEqual(obj.created_at, now(), delta=timedelta(seconds=1))

    def test_updated_at_field_on_save(self):
        obj = TestModelUpdatedAt.objects.create()
        initial_updated_at = obj.updated_at
        obj.save()
        self.assertGreater(obj.updated_at, initial_updated_at)

    def test_deleted_at_model_soft_delete(self):
        obj = TestModelDeletedAt.objects.create()
        self.assertIsNone(obj.deleted_at)

        obj.soft_delete()
        self.assertIsNotNone(obj.deleted_at)
        self.assertAlmostEqual(obj.deleted_at, now(), delta=timedelta(seconds=1))

        self.assertFalse(TestModelDeletedAt.objects.filter(id=obj.id).exists())
        self.assertEqual(TestModelDeletedAt.objects.count(), 0)

    def test_deleted_at_model_manager_methods(self):
        obj_live = TestModelDeletedAt.objects.create()
        obj_deleted = TestModelDeletedAt.objects.create()
        obj_deleted.soft_delete()

        self.assertIn(obj_live, TestModelDeletedAt.objects.all())
        self.assertNotIn(obj_deleted, TestModelDeletedAt.objects.all())

        self.assertIn(obj_deleted, TestModelDeletedAt.objects.deleted())
        self.assertNotIn(obj_live, TestModelDeletedAt.objects.deleted())

        all_objs = TestModelDeletedAt.objects.all_with_deleted()
        self.assertIn(obj_live, all_objs)
        self.assertIn(obj_deleted, all_objs)

    def test_deleted_at_model_restore(self):
        obj = TestModelDeletedAt.objects.create()
        obj.soft_delete()
        self.assertFalse(TestModelDeletedAt.objects.filter(id=obj.id).exists())

        obj.restore()
        self.assertIsNone(obj.deleted_at)
        self.assertTrue(TestModelDeletedAt.objects.filter(id=obj.id).exists())
