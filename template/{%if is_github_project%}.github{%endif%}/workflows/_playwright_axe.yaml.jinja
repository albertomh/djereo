# Run Playwright accessibility tests in CI.
#
# Usage:
# ```
# jobs:
#   accessibility:
#     needs: containerise
#     uses: ./.github/workflows/_playwright_axe.yaml
#     with:
#       image_address: {% raw %}${{ needs.containerise.outputs.image_address }}{% endraw +%}
# ```
name: Accessibility tests

on:
  workflow_call:
    inputs:
      image_address:
        required: true
        type: string

jobs:
  axe:
    runs-on: ubuntu-24.04
    env:
      USE_ENV_TEST: "1"
      SECRET_KEY: django-insecure_not-a-secret
      ALLOWED_HOSTS: localhost,127.0.0.1,::1
      CSRF_TRUSTED_ORIGINS: http://127.0.0.1
      EMAIL_HOST: host.docker.internal
      DATABASE_URL: postgres://{{ project_name }}:password@host.docker.internal:5432/{{ project_name }}
    services:
      postgres:
        image: postgres:18
        env:
          POSTGRES_DB: {{ project_name }}
          POSTGRES_USER: {{ project_name }}
          POSTGRES_PASSWORD: password
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v6

      - name: Log in to GHCR
        uses: docker/login-action@v4
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ github.token }}{% endraw %}

      - uses: astral-sh/setup-uv@v8.2.0
        with:
          version: "0.11.9"
          enable-cache: true

      - name: Create Docker network
        run: docker network create test-network

      - name: Run Mailpit in network
        run: |
            docker run --detach \
              --name mailpit \
              --network test-network \
              --env TZ=Europe/London \
              -p 1025:1025 \
              -p 8025:8025 \
              axllent/mailpit:v1.27

      - name: Apply migrations and seed database
        run: |
          docker run --rm \
            --add-host=host.docker.internal:host-gateway \
            --env USE_ENV_TEST \
            --env SECRET_KEY \
            --env ALLOWED_HOSTS \
            --env CSRF_TRUSTED_ORIGINS \
            --env DATABASE_URL \
{% raw %}            ${{ inputs.image_address }} \{% endraw +%}
            /bin/bash -c "python manage.py migrate && python manage.py seed_database"

      - name: Run webapp in the background
        run: |
          docker run --detach \
            --name webapp \
            --network test-network \
            --add-host=host.docker.internal:host-gateway \
            --env USE_ENV_TEST \
            --env SECRET_KEY \
            --env ALLOWED_HOSTS \
            --env CSRF_TRUSTED_ORIGINS \
            --env EMAIL_HOST \
            --env DATABASE_URL \
            --env PORT=8000 \
            --publish 8000:8000 \
            --volume testdjereo_static:/app/static \
{% raw %}            ${{ inputs.image_address }}{% endraw +%}

      - name: Cache Playwright browsers
        id: cache-playwright
        uses: actions/cache@v5
        with:
          path: ~/.cache/ms-playwright
          key: {% raw %}playwright-${{ runner.os }}-${{ hashFiles('uv.lock') }}-chromium{% endraw +%}

      - run: uv sync --group=test

      - if: {% raw %}${{ steps.cache-playwright.outputs.cache-hit != 'true' }}{% endraw +%}
        run: uv run playwright install --with-deps chromium

      - run: uv run pytest tests_e2e/ -m axe
